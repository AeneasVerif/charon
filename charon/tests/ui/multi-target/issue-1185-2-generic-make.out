unsafe fn test_crate::State::{impl core::marker::Destruct for test_crate::State<H>}::drop_glue<H>(_1: *mut test_crate::State<H>)
{
    let _0: (); // return
    let _1: &'1 mut test_crate::State<H>; // arg #1

    _0 = ()
    drop[{built_in impl core::marker::Destruct for H}::drop_glue] ((*_1))._h
