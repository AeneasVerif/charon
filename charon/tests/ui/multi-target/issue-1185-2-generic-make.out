pub fn test_crate::caller<H>(h_1: H)
{
    let _0: (); // return
    let h_1: H; // arg #1
    let _2: test_crate::State<H>; // anonymous local
    let _3: H; // anonymous local

    _0 = ()
    storage_live(_2)
