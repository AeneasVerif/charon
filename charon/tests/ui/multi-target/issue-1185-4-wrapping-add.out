pub fn core::num::{u32}::wrapping_add(_1: u32, _2: u32) -> u32
= <opaque>

pub fn test_crate::mod_reduce(a: u32) -> u32
{
    let _0: u32; // return
    let a: u32; // arg #1
    let _2: bool; // anonymous local
    let _3: u32; // anonymous local
    let _4: u32; // anonymous local

    storage_live(_0)
    storage_live(_2)
    storage_live(_3)
    _3 = copy a
    _2 = move _3 < const 100u32
    assert(move _2 == true) else panic(core::panicking::panic)
    ↳⚡ unwind_continue
    storage_dead(_3)
    storage_dead(_2)
    storage_live(_4)
    _4 = copy a
    _0 = core::num::{u32}::wrapping_add(move _4, const 1u32)
    ↳⚡ storage_dead(a)
        unwind_continue
    storage_dead(_4)
    storage_dead(a)
    return
}


