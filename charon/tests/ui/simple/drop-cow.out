unsafe fn drop_glue<'a, '_1, B>(_1: &'_1 mut Cow<'a, B>[TraitClause0, TraitClause1, TraitClause2])
where
    TraitClause0: (B: MetaSized),
    TraitClause1: (B: ToOwned),
    TraitClause2: (B: Destruct),
    TypeOutlives0: B: 'a,
    TypeOutlives1: B: 'a,
