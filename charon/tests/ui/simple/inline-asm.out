# Final LLBC before serialization:

// Full name: test_crate::main
fn main()
{
    let _0: (); // return

    _0 = ()
    asm!("nop")
    _0 = ()
    return
}

// Full name: test_crate::multiple_targets
fn multiple_targets(x_1: u32) -> u32
{
    let _0: u32; // return
    let x_1: u32; // arg #1

    asm!("jmp {0}") {
        target 0 => {
            _0 = copy x_1
            return
        }
        target 1 => {
            x_1 = const 1 : u32
            _0 = copy x_1
            return
        }
    }
}



