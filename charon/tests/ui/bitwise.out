// Full name: test_crate::shift_u32
pub fn shift_u32(a: u32) -> u32
{
    let _0: u32; // return
    let a: u32; // arg #1
    let i: usize; // local
    let t: u32; // local
    let _4: u32; // anonymous local
    let _5: usize; // anonymous local
    let _6: usize; // anonymous local

    storage_live(i)
    i = const 16usize
    storage_live(t)
    storage_live(_4)
    _4 = copy a
    storage_live(_5)
    _5 = copy i
    t = move _4 panic.>> move _5
    storage_dead(_5)
    storage_dead(_4)
    storage_live(_6)
    _6 = copy i
    t = copy t panic.<< move _6
    storage_dead(_6)
    _0 = copy t
    storage_dead(t)
    storage_dead(i)
    return
}

