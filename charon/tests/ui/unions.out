# Final LLBC before serialization:

// Full name: test_crate::Foo
union Foo {
  one: u64,
  two: [u32; 2usize],
}

// Full name: test_crate::use_union
fn use_union()
{
    let _0: (); // return
    let one: Foo; // local
    let _two: [u32; 2usize]; // local

    _0 = ()
    storage_live(one)
    one = Foo { one: const 42u64 }
    (one).one = const 43u64
    storage_live(_two)
    _two = copy (one).two
    _0 = ()
    storage_dead(_two)
    storage_dead(one)
    return
}



